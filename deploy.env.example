DREAMHOST_SSH_HOST=example.com
DREAMHOST_SSH_USER=dh-shell-user
DREAMHOST_REMOTE_PATH=/home/dh-shell-user/example.com/analytics
DREAMHOST_SSH_PORT=22

# Set to 1 only after the remote directory is known-good and you want rsync
# to remove old tracked files that no longer exist locally.
RSYNC_DELETE=0
